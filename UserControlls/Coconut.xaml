<UserControl x:Class="Snake.UserControlls.Coconut"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Snake.UserControlls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="50">
    <Canvas Width="50" Height="50">
        
        <!--Kokosnuss ist von ChatGPT, weil ich in XAML nicht zeichnen kann
        und auch generell nicht zeichnen kann
        Prompt: 
        mache mir eine kokosnuss in wpf xaml, sie soll ein usercontrol sein 
        und 50x50, mache sie detailliert-->
        
        <!-- Schatten -->
        <Ellipse Width="40" Height="12"
                 Canvas.Left="5" Canvas.Top="35"
                 Fill="#33000000"/>

        <!-- Hauptkörper -->
        <Ellipse Width="40" Height="40"
                 Canvas.Left="5" Canvas.Top="5">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#8B5A2B" Offset="0"/>
                    <GradientStop Color="#5C3A1E" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Struktur (Fasern) -->
        <Path Stroke="#3E2615" StrokeThickness="0.8" Opacity="0.6"
              Data="M10,20 Q25,10 40,20" HorizontalAlignment="Center" Canvas.Top="30.181" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Canvas.Left="7.636">
            <Path.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-180.984"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Path.RenderTransform>
        </Path>
        <Path Stroke="#3E2615" StrokeThickness="0.8" Opacity="0.6"
              Data="M10,25 Q25,15 40,25" HorizontalAlignment="Center" Canvas.Top="34.321" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Canvas.Left="9.13">
            <Path.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-179.87"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Path.RenderTransform>
        </Path>

        <!-- Kokosnuss-Löcher -->
        <Ellipse Width="4" Height="4" Fill="#2B1A0F"
                 Canvas.Left="20" Canvas.Top="18"/>
        <Ellipse Width="4" Height="4" Fill="#2B1A0F"
                 Canvas.Left="25" Canvas.Top="22"/>
        <Ellipse Width="4" Height="4" Fill="#2B1A0F"
                 Canvas.Left="17" Canvas.Top="24"/>

        <!-- Lichtreflex -->
        <Ellipse Width="12" Height="8"
                 Canvas.Left="12" Canvas.Top="10"
                 Opacity="0.25">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="White" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
    </Canvas>
</UserControl>
