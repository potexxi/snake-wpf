<Page x:Class="Snake.Pages.PageGame"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Snake.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageGame" Name="PageMain">

    <Canvas x:Name="CanvasAll">
        <Grid Background="#FF282828" x:Name="GridMain">
            <StackPanel>
                <Label x:Name="LabelScore" Content="Score: 0" Foreground="White" FontSize="40" HorizontalContentAlignment="Center" FontFamily="Bahnschrift SemiBold SemiCondensed"></Label>
                <Canvas x:Name="CanvasField"></Canvas>
            </StackPanel>
        </Grid>
    </Canvas>
</Page>
