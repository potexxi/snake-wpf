<Page x:Class="Snake.Pages.PageInfo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Snake.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="600"
      Title="PageInfo">

    <Grid Background="#0A0F2C">
        <!-- ChatGPT anfang Prompt: <code vom "Snake-TextBlock"> mache mir die Buttons im gleichen Retro-Style wie diese TextBlock und gebe mir eine style zurueck, dass es auf alle buttons angewendet wird-->
        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="Foreground" Value="#4FC3FF"/>
                <Setter Property="Background" Value="#050A1A"/>
                <Setter Property="BorderBrush" Value="#4FC3FF"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Height" Value="45"/>
                <Setter Property="Width" Value="230"/>
                <Setter Property="Margin" Value="0,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#4FC3FF" BlurRadius="15"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#0D1A3A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <!--ChatGPT ende-->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-30,0,0">
            <TextBlock Margin="0,15,0,0" Text="INFO" Foreground="#4FC3FF" FontSize="60" FontFamily="Bahnschrift SemiBold" HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#4FC3FF" BlurRadius="25"/>
                </TextBlock.Effect></TextBlock>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
                <TextBlock FontSize="13" Text="This Snake game was developed as a school project. The goal was to recreate the classic game while learning programming concepts and game development." Foreground="LightGray" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="About this Project" FontSize="23" Foreground="White" Margin="0,10,0,5"/>
                <TextBlock FontSize="13"  Text="• Developed independently&#x0a;• Built using C# and WPF&#x0a;• Simple but expandable design" Foreground="LightGray" Margin="0,0,0,20"/>
                <TextBlock Text="Source Code" FontSize="23" Foreground="White" Margin="0,10,0,5"/>
                <TextBlock FontSize="13" TextAlignment="Left">
                 <!--CHATGPT anfang-->
                <Hyperlink Foreground="White" NavigateUri="https://github.com/potexxi/snake-wpf" RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="View Project on GitHub"/>
                </Hyperlink>
                    <!--CHATGPT ende-->
                </TextBlock>
            </StackPanel>
            <Button x:Name="ButtonBack" Content="> Back to menu" Margin="0,30,0,0" Click="ButtonBack_Click"></Button>
        </StackPanel>
    </Grid>
</Page>
