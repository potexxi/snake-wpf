<Page x:Class="Snake.Pages.PageMenu" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="PageMenu" Width="600" Height="450">
    <Grid Background="#0A0F2C">
        <!-- ChatGPT anfang Prompt: <code vom "Snake-TextBlock"> mache mir die Buttons im gleichen Retro-Style wie diese TextBlock und gebe mir eine style zurueck, dass es auf alle buttons angewendet wird-->
        <Grid.Resources>
            <Style TargetType="Button">
                <Setter Property="Foreground" Value="#4FC3FF"/>
                <Setter Property="Background" Value="#050A1A"/>
                <Setter Property="BorderBrush" Value="#4FC3FF"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Height" Value="50"/>
                <Setter Property="Width" Value="240"/>
                <Setter Property="Margin" Value="0,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#4FC3FF" BlurRadius="15"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#0D1A3A"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <!--ChatGPT ende-->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-30,0,0">
            <StackPanel Orientation="Horizontal" Width="600">
                <TextBlock Margin="198,0,0,0" Text="SNAKE" Foreground="#4FC3FF" FontSize="65" FontFamily="Bahnschrift SemiBold" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#4FC3FF" BlurRadius="25"/>
                    </TextBlock.Effect></TextBlock>
                <Label Cursor="Hand" PreviewMouseDown="Label_PreviewMouseDown" MouseLeave="Label_MouseLeave" MouseEnter="Label_MouseEnter" Margin="120,0,0,0" Content="🛈" FontSize="45" Foreground="White"></Label>
            </StackPanel>
            <TextBlock Text="by Potexxi" Foreground="#4FC3FF" FontSize="14" FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,-5,0,20"/>
            <Button x:Name="ButtonPlayNew" Content="> NEW GAME" Click="ButtonPlayNew_Click"/>
            <Button x:Name="ButtonPlaySaved" Content="> CONTINUE" Click="ButtonPlaySaved_Click"/>
            <Button x:Name="ButtonRanked" Content="> SCOREBOARD" Click="ButtonRanked_Click"/>
            <Button x:Name="ButtonSettings" Content="> SETTINGS" Click="ButtonSettings_Click"/>
        </StackPanel>
    </Grid>
</Page>